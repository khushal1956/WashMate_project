<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFeaturedOffer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="12dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="#40FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:background="@drawable/bg_featured_offer_gradient">

        <!-- Decorative background elements -->
        <View
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:background="@drawable/bg_circle_white"
            android:alpha="0.05"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="-100dp"
            android:layout_marginTop="-100dp" />

        <LinearLayout
            android:id="@+id/layoutTextContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ivFeaturedIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_pill"
                android:backgroundTint="#40000000"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="SPECIAL OFFER"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvFeaturedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="30% OFF"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:textStyle="bold"

                android:lineSpacingExtra="4sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvFeaturedSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="on your first session"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:id="@+id/layoutPromoBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_glass_pill"
                android:backgroundTint="#33000000"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="3dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:text="USE CODE"
                    android:textColor="#CCFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_pill"
                    android:backgroundTint="@color/white"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvFeaturedCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WASH30"
                        android:textColor="#03045E"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:fontFamily="monospace" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="10dp"
                        android:src="@drawable/ic_copy"
                        app:tint="#03045E" />
                </LinearLayout>
            </LinearLayout>





        </LinearLayout>

        <ImageView
            android:id="@+id/ivFeaturedIllustration"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_wm_premium"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:alpha="0.9" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
