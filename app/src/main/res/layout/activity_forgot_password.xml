<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".ForgotPasswordActivity">

    <!-- Background overlay -->
    <View
        android:id="@+id/headerBackgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/desertPrimary"
        android:alpha="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardForgotPassword"
        app:layout_constraintHeight_percent="0.4" />

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@color/desertDark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Icon -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/iconContainer"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="24dp"
        android:elevation="8dp"
        app:cardBackgroundColor="@color/desertBg"
        app:cardCornerRadius="50dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/cardForgotPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:scaleType="fitCenter"
            app:tint="@color/desertPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Card Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardForgotPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        style="@style/GlassCardPremium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.55">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Password"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/desertDark"
                    android:letterSpacing="-0.03" />

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your email to receive an OTP"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"
                    android:textColor="@color/textColorSecondary" />

                <!-- Email Input Section -->
                <LinearLayout
                    android:id="@+id/layoutEmailSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DesertInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Email Address"
                        app:startIconDrawable="@android:drawable/ic_dialog_email">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="16dp"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/desertDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSendOtp"
                        style="@style/PillButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="SEND OTP"
                        android:textAllCaps="true"
                        android:backgroundTint="@color/desertPrimary"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- OTP Verification Section -->
                <LinearLayout
                    android:id="@+id/layoutOtpSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DesertInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Enter OTP"
                        app:startIconDrawable="@android:drawable/ic_dialog_info">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etOtp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="16dp"
                            android:inputType="number"
                            android:maxLength="6"
                            android:textColor="@color/desertDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnVerifyOtp"
                        style="@style/PillButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="VERIFY OTP"
                        android:textAllCaps="true"
                        android:backgroundTint="@color/slatePrimary"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvResendOtp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:padding="8dp"
                        android:text="Resend OTP"
                        android:textColor="@color/desertPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Password Reset Section -->
                <LinearLayout
                    android:id="@+id/layoutPasswordSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DesertInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="New Password"
                        app:passwordToggleEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="16dp"
                            android:inputType="textPassword"
                            android:textColor="@color/desertDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DesertInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Confirm Password"
                        app:passwordToggleEnabled="true"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="16dp"
                            android:inputType="textPassword"
                            android:textColor="@color/desertDark" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnResetPassword"
                        style="@style/PillButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="RESET PASSWORD"
                        android:textAllCaps="true"
                        android:backgroundTint="@color/slatePrimary"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Progress Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/desertPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
