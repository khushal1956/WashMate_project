<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1E293B"
    app:cardBackgroundColor="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Name, ID, Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCustomerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Name"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #12345678"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="#0A0F14"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_glass_card"
                android:backgroundTint="@color/stitch_primary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E293B"
            android:layout_marginBottom="16dp"/>

        <!-- Details Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4">

            <!-- Service & Date Labels -->
            <TextView
                android:text="Service"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:text="Pickup Date"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <!-- Service & Date Values -->
            <TextView
                android:id="@+id/tvServiceName"
                android:text="Regular Wash"
                android:textColor="#CBD5E1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvPickupDate"
                android:text="May 20, 2026"
                android:textColor="#CBD5E1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="12dp"/>

            <!-- Items & Total Labels -->
            <TextView
                android:text="Items Count"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>
             <TextView
                android:text="Total Amount"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <!-- Items & Total Values -->
            <TextView
                android:id="@+id/tvQuantity"
                android:text="5 items"
                android:textColor="#CBD5E1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="12dp"/>
             <TextView
                android:id="@+id/tvTotalAmount"
                android:text="₹150"
                android:textColor="@color/stitch_primary"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="12dp"/>
        </GridLayout>

        <!-- Extra Details Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0AFFFFFF"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">
             
            <TextView
                android:id="@+id/tvServiceType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Type: Express"
                android:textSize="12sp"
                android:textColor="#94A3B8"/>
             <TextView
                android:id="@+id/tvItemDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2 Shirts, 3 Pants"
                android:textSize="13sp"
                android:textColor="#CBD5E1"
                android:layout_marginTop="4dp"/>
             <TextView
                android:id="@+id/tvPickupAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="123 Street Name, City"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="10dp"/>
             <TextView
                android:id="@+id/tvPaymentMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment: Online"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:id="@+id/llActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Reject"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#EF4444"
                app:cornerRadius="16dp"
                app:backgroundTint="#1AEF4444"
                app:strokeWidth="1dp"
                app:strokeColor="#40EF4444"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Accept"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#0A0F14"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/stitch_primary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Assign Button Section -->
        <LinearLayout
            android:id="@+id/llAssignButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
             <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAssign"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Assign to Specialist"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:icon="@android:drawable/ic_menu_my_calendar"
                app:iconGravity="textStart"
                app:iconTint="#0A0F14"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/stitch_primary"
                android:textColor="#0A0F14" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
