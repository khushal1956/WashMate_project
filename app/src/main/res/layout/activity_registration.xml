<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_bg_gradient"
    tools:context=".RegistrationActivity">

    <!-- Header Section -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Back Button -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="56dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvWashMateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="WashMate"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Centered Logo -->
    <ImageView
        android:id="@+id/logoIcon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_wm_premium"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_max="80dp"
        app:layout_constraintWidth_max="80dp"
        app:layout_constraintBottom_toTopOf="@id/guideline_h"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWashMateTitle"
        app:layout_constraintVertical_bias="0.4" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.22" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_h"
        app:layout_constraintVertical_bias="0.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- Glass Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardRegistration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_bg"
                android:paddingHorizontal="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/join_us"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:alpha="0.8"
                    android:text="@string/registration_subtitle"
                    android:textColor="@color/glassTextPrimary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />

                <!-- Progress Bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressRegistration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:progress="20"
                    app:indicatorColor="@color/washmateAccent"
                    app:trackColor="@color/glass_white_10"
                    app:trackCornerRadius="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

                <TextView
                    android:id="@+id/tvProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Step 1 of 3"
                    android:textColor="@color/glassTextSecondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressRegistration" />

                <!-- Form Container -->
                <FrameLayout
                    android:id="@+id/flFormContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvProgressText">

                    <!-- STEP 1: Personal Info -->
                    <LinearLayout
                        android:id="@+id/llStep1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <!-- Profile Photo -->
                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivProfilePhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:background="@color/glass_white_10"
                                app:srcCompat="@drawable/ic_person_24dp"
                                app:tint="@color/glassTextSecondary"
                                android:padding="24dp"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="bottom|end"
                                android:background="@drawable/logo_circle_bg"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="@color/white"
                                android:padding="6dp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="@string/profile_photo"
                            android:textColor="@color/glassTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:id="@+id/tvFullNameLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/full_name"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFullName"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/full_name"
                                android:inputType="textPersonName"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/tvEmailLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/email_hint"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/email_hint_example"
                                android:inputType="textEmailAddress"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Gender Dropdown -->
                        <TextView
                            android:id="@+id/tvGenderLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/gender_hint"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGender"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">

                            <AutoCompleteTextView
                                android:id="@+id/actvGender"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/select_gender"
                                android:inputType="none"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp"
                                android:popupBackground="@color/glass_bg_bottom"
                                android:fontFamily="sans-serif-medium" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNextStep1"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="24dp"
                            android:backgroundTint="@color/washmatePrimary"
                            android:text="@string/next"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="28dp" />
                    </LinearLayout>

                    <!-- STEP 2: Mobile and Address -->
                    <LinearLayout
                        android:id="@+id/llStep2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvMobileLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/mobile_number"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMobile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMobile"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/mobile_number"
                                android:inputType="phone"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/tvAddressLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/home_address"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/ic_location"
                            app:endIconTint="@color/glassTextSecondary"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAddress"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/home_address"
                                android:inputType="textPostalAddress"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- City -->
                        <TextView
                            android:id="@+id/tvCityLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="City"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCity"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="City"
                                android:inputType="textCapWords"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Pincode -->
                        <TextView
                            android:id="@+id/tvPincodeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/pincode_hint"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPincode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPincode"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="@string/pincode_hint"
                                android:inputType="number"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:maxLength="6"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBackStep2"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="@string/back"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="28dp"
                                app:strokeColor="@color/washmateAccent" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnNextStep2"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="@color/washmatePrimary"
                                android:text="@string/next"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="28dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- STEP 3: Passwords -->
                    <LinearLayout
                        android:id="@+id/llStep3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvPasswordLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/password_hint"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="@color/glassTextSecondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="••••••••"
                                android:inputType="textPassword"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/tvConfirmPasswordLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/confirm_password"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:errorTextColor="@color/design_default_color_error"
                            app:hintEnabled="false"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="@color/glassTextSecondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConfirmPassword"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/glass_input_selector"
                                android:hint="••••••••"
                                android:inputType="textPassword"
                                android:paddingHorizontal="20dp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/glassTextSecondary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBackStep3"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="@string/back"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="28dp"
                                app:strokeColor="@color/washmateAccent" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRegister"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1.5"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="@color/washmatePrimary"
                                android:text="@string/create_account"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="28dp" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

                <!-- Login Prompt -->
                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/already_registered"
                    android:textColor="@color/washmateAccent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/flFormContainer" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:alpha="0.5"
                android:text="@string/secure_wash_footer"
                android:textColor="@color/glassTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardRegistration" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
