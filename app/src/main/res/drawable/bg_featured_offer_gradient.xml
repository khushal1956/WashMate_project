<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#1E3A8A"
                android:centerColor="#2563EB"
                android:endColor="#3B82F6"
                android:angle="45" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Top-right highlight -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerX="0.9"
                android:centerY="0.1" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Bottom-left accent -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#22000000"
                android:endColor="#00000000"
                android:centerX="0.1"
                android:centerY="0.9" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
