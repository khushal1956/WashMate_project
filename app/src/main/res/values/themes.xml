<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WashMate_Laundary_Service" parent="Theme.Material3.Light.NoActionBar">
        <!-- Core Colors -->
        <item name="colorPrimary">@color/washmatePrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/washmateAccent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/washmateBg</item>
        <item name="android:statusBarColor">@color/washmatePrimary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Typography hints -->
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <style name="Theme.WashMate_Laundary_Service" parent="Base.Theme.WashMate_Laundary_Service" />

    <!-- Card Style -->
    <style name="WashMateCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Button Style -->
    <style name="WashMateButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Input Field Style -->
    <style name="WashMateInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/washmatePrimary</item>
        <item name="hintTextColor">@color/washmatePrimary</item>
        <item name="android:textColorHint">@color/textHint</item>
    </style>
    
    <!-- Legacy Mappings -->
    <style name="GlassCard" parent="WashMateCard" />
    <style name="PillButton" parent="WashMateButton" />
    <style name="DesertInput" parent="WashMateInput" />

    <!-- Missing Styles Fix -->
    <style name="ShapeAppearance.App.Circle" parent="ShapeAppearance.Material3.Corner.Full" />
    
    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="GlassCardPremium" parent="WashMateCard">
        <item name="cardBackgroundColor">#F0F8FF</item>
        <item name="strokeColor">@color/washmateAccent</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Bottom Nav Text Styles -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/washmatePrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>